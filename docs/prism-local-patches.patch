# Local modifications to vendored prism (third_party/prism), atop upstream v0.16.5
# Regenerate after a prism update by re-applying these two changes by hand.
# 1) backend_registry.cpp: SEH-guard each initialize() in acquire_best/create_best (crash fix; upstream PR candidate).
# 2) CMakeLists.txt: pin CMAKE_C_STANDARD to 17 (our CMake/MSVC can't map C23; build-env only).

diff --git a/build/prism-0.16.5/CMakeLists.txt b/third_party/prism/CMakeLists.txt
index 0d7ecac..4ccc030 100644
--- a/build/prism-0.16.5/CMakeLists.txt
+++ b/third_party/prism/CMakeLists.txt
@@ -13,7 +13,12 @@ include(ExternalProject)
 set(CMAKE_EXPORT_COMPILE_COMMANDS ON)
 set(CMAKE_CXX_STANDARD 23)
 set(CMAKE_CXX_STANDARD_REQUIRED ON)
-set(CMAKE_C_STANDARD 23)
+# Local build-compat patch (voice-of-the-old-republic): upstream sets
+# CMAKE_C_STANDARD 23, but our toolchain's CMake can't map C23 onto MSVC
+# (try_compile ABI detection fails). prism's C code only needs C17 anyway —
+# target_compile_features below declares c_std_17, not c_std_23 — so pin the
+# global default to 17. Pure build-environment fix; no source/ABI change.
+set(CMAKE_C_STANDARD 17)
 set(CMAKE_C_STANDARD_REQUIRED ON)
 

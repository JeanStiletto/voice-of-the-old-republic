# Build artifacts and run logs
/build/
**/logs/

# .NET build output (kdev, dbgcapture)
**/bin/
**/obj/

# Visual Studio / Rider local files
.vs/
.idea/
*.user
*.suo

# OS / editor
.DS_Store
Thumbs.db
*~
*.swp

# Claude Code local-only config (per-user permissions/hooks + runtime state)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Internal dev tooling — kdev (build/install/launch CLI), dbgcapture
# (OutputDebugString sink), ghidra-scripts. Excluded from the public repo
# for now; may be released separately later.
/tools/

# Decompiled / reverse-engineered game artifacts: Lane Dibello's Ghidra
# database (gzf/xml/sarif/h) and architecture PDF. Not redistributable —
# mirror locally from his Google Drive (links: https://deadlystream.com/topic/11948-kotor-1-gog-reverse-engineering/).
/docs/llm-docs/

# Upstream third-party clones — recreatable from public repos:
#   KotorMessageInjector: https://github.com/LaneDibello/KotorMessageInjector
#   KotOR_IO: https://github.com/LaneDibello/KotOR_IO
#   DLZ-Tool: https://github.com/Lane-Dibello/DLZ-Tool
# Tolk (third_party/tolk/) is kept — LGPL distribution requirement.
#
# Kotor-Patch-Manager is intentionally NOT ignored: we vendor it so our
# framework modifications travel with normal commits. The upstream commit
# we forked from is recorded in docs/framework-changes-backup.patch.
/third_party/KotorMessageInjector/
/third_party/KotOR_IO/
/third_party/DLZ-Tool/
# dsoal — read-only reference clone; we ship the prebuilt binaries
# bundled in the installer Resources/ folder, not the source.
/third_party/dsoal/

# Prism — vendored source clone at third_party/prism/ for rebuildability,
# vendored prebuilt artifacts at third_party/prism-dist/ for kdev apply.
# Build trees + clone metadata are throwaway; the prebuilt artifacts ARE
# committed so the patch ships without requiring users to build Prism.
/third_party/prism/build_*/
/third_party/prism/.git/
/third_party/prism/.github/
/third_party/prism/.cache/
/third_party/prism/gdextension/godot-cpp/
